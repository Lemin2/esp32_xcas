# Tab5 display path follows the M5Stack UserDemo memory/cache profile closely.
# The MIPI-DSI panel fetches from external RAM; slower PSRAM/cache settings can
# trigger LCD underruns under LVGL load.
CONFIG_SPIRAM_SPEED_200M=y
CONFIG_SPIRAM_SPEED=200
CONFIG_SPIRAM_XIP_FROM_PSRAM=y
CONFIG_SPIRAM_FETCH_INSTRUCTIONS=y
CONFIG_SPIRAM_RODATA=y
CONFIG_SPIRAM_FLASH_LOAD_TO_PSRAM=y
CONFIG_CACHE_L2_CACHE_256KB=y
CONFIG_CACHE_L2_CACHE_SIZE=0x40000
CONFIG_CACHE_L2_CACHE_LINE_128B=y
CONFIG_CACHE_L2_CACHE_LINE_SIZE=128
CONFIG_FREERTOS_HZ=1000
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_tab5.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions_tab5.csv"
CONFIG_LV_USE_TINY_TTF=y
CONFIG_LV_TINY_TTF_FILE_SUPPORT=y
CONFIG_LV_TINY_TTF_CACHE_GLYPH_CNT=96
CONFIG_LV_USE_FS_STDIO=y
CONFIG_LV_FS_STDIO_LETTER=65
CONFIG_LV_FS_STDIO_PATH=""

# Tab5 automation uses the board USB COM port. Bind stdin/stdout to USB-SERIAL-JTAG
# instead of GPIO UART0 so ESP-IDF monitor and ML debug commands can write back.
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y